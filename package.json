{
  "name": "priors",
  "private": false,
  "version": "1.1.0-rc.2",
  "description": "Always-on project memory for Claude Code and Cursor. Decisions, dead ends, constraints, and rules survive sessions; agents push back on rejected approaches automatically.",
  "author": "Claudia Nathan (https://github.com/claudialnathan)",
  "type": "module",
  "bin": {
    "priors": "bin/priors.js"
  },
  "preferGlobal": true,
  "scripts": {
    "test": "node --test 'tests/unit/**/*.test.ts' 'tests/snapshots/**/*.test.ts' 'tests/regression/**/*.test.ts' 'tests/grounding/**/*.test.ts'",
    "test:unit": "node --test 'tests/unit/**/*.test.ts'",
    "test:snapshots": "node --test 'tests/snapshots/**/*.test.ts'",
    "test:regression": "node --test 'tests/regression/**/*.test.ts'",
    "brief": "node bin/priors.js brief --project-root \"$PWD\"",
    "mcp": "node bin/priors.js mcp --project-root \"$PWD\""
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "AGENTS.md",
    "CLAUDE.md",
    "bin/",
    ".claude-plugin/",
    "skills/",
    "agents/",
    "hooks/",
    ".mcp.json",
    ".cursor/mcp.json",
    ".cursor/rules/",
    "docs/evals.md",
    "docs/integrations.md",
    "docs/mcp-architecture.md",
    "docs/plugin-architecture.md",
    "docs/maintainer-guide.md",
    "docs/specs/",
    "src/"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents",
    "memory",
    "project-memory",
    "claude-code",
    "cursor",
    "codex",
    "harness"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudialnathan/priors.git"
  },
  "engines": {
    "node": ">=25"
  },
  "license": "MIT"
}
