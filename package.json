{
  "name": "priors",
  "private": false,
  "version": "1.0.0-rc.1",
  "description": "Persistent project state for autonomous agents. An append-only log of decisions and constraints that agents write and inherit across context resets.",
  "author": "Claudia Nathan (https://github.com/claudialnathan)",
  "type": "module",
  "bin": {
    "priors": "bin/priors.js"
  },
  "preferGlobal": true,
  "scripts": {
    "test": "node --test 'tests/unit/**/*.test.ts' 'tests/snapshots/**/*.test.ts' 'tests/regression/**/*.test.ts' 'tests/grounding/**/*.test.ts'",
    "test:unit": "node --test 'tests/unit/**/*.test.ts'",
    "test:snapshots": "node --test 'tests/snapshots/**/*.test.ts'",
    "test:regression": "node --test 'tests/regression/**/*.test.ts'",
    "brief": "node bin/priors.js brief --project-root \"$PWD\"",
    "mcp": "node bin/priors.js mcp --project-root \"$PWD\""
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "bin/",
    "docs/evals.md",
    "docs/integrations.md",
    "docs/mcp-architecture.md",
    "docs/specs/",
    "src/"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents",
    "memory",
    "project-memory",
    "claude-code",
    "cursor",
    "codex",
    "harness"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudialnathan/priors.git"
  },
  "engines": {
    "node": ">=25"
  },
  "license": "MIT"
}
